{
  "name": "ssh-system-architect",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "ssh-system-architect",
      "version": "0.1.0",
      "workspaces": [
        "packages/*",
        "examples/demo_sharded_snake/apps/*",
        "examples/demo_sharded_snake/services/*",
        "examples/demo_sharded_snake/packages/*"
      ]
    },
    "examples/demo_sharded_snake/apps/web_gateway": {
      "name": "@demo-sharded-snake/web-gateway",
      "version": "0.1.0"
    },
    "examples/demo_sharded_snake/packages/shared_protocol": {
      "name": "@demo-sharded-snake/shared-protocol",
      "version": "0.1.0"
    },
    "examples/demo_sharded_snake/services/snake_shard": {
      "name": "@demo-sharded-snake/snake-shard",
      "version": "0.1.0"
    },
    "node_modules/@demo-sharded-snake/shared-protocol": {
      "resolved": "examples/demo_sharded_snake/packages/shared_protocol",
      "link": true
    },
    "node_modules/@demo-sharded-snake/snake-shard": {
      "resolved": "examples/demo_sharded_snake/services/snake_shard",
      "link": true
    },
    "node_modules/@demo-sharded-snake/web-gateway": {
      "resolved": "examples/demo_sharded_snake/apps/web_gateway",
      "link": true
    },
    "node_modules/@ssh-system-architect/remote-infra-core": {
      "resolved": "packages/remote-infra-core",
      "link": true
    },
    "node_modules/@ssh-system-architect/remote-infra-mcp": {
      "resolved": "packages/remote-infra-mcp",
      "link": true
    },
    "node_modules/@ssh-system-architect/remote-infra-types": {
      "resolved": "packages/remote-infra-types",
      "link": true
    },
    "packages/remote-infra-core": {
      "name": "@ssh-system-architect/remote-infra-core",
      "version": "0.1.0"
    },
    "packages/remote-infra-mcp": {
      "name": "@ssh-system-architect/remote-infra-mcp",
      "version": "0.1.0",
      "bin": {
        "remote-infra-mcp": "src/main.ts"
      }
    },
    "packages/remote-infra-types": {
      "name": "@ssh-system-architect/remote-infra-types",
      "version": "0.1.0"
    }
  }
}
